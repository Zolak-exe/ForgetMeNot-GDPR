# ─── Serveur ──────────────────────────────────────────────────────────────
PORT=

# ─── HaveIBeenPwned (optionnel) ───────────────────────────────────────────
# Récupère ta clé sur https://haveibeenpwned.com/API/Key (3,50$/mois)
# Si vide → on skip HIBP et on se base uniquement sur le scan IMAP
HIBP_API_KEY=

# ─── IMAP par défaut (optionnel) ──────────────────────────────────────────
# Tu peux aussi remplir le formulaire dans l'UI à chaque scan
# Pour ProtonMail il te faut lancer ProtonMail Bridge en local
IMAP_HOST=
IMAP_PORT=
IMAP_USER=
IMAP_PASS=
IMAP_TLS=
