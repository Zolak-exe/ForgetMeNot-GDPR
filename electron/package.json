{
  "name": "identity-scanner-electron",
  "version": "1.0.0",
  "description": "Scanner d'empreinte numérique et outil RGPD.",
  "main": "main.js",
  "scripts": {
    "build:server": "node scripts/build-server.mjs",
    "prestart": "npm run build:server",
    "start": "electron-forge start",
    "prepackage": "npm run build:server",
    "package": "electron-forge package",
    "premake": "npm run build:server",
    "make": "electron-forge make",
    "make-linux": "npm run build:server && electron-forge make --platform=linux --arch=x64"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "electron": "^42.5.0",
    "esbuild": "^0.24.0"
  },
  "keywords": [
    "gdpr",
    "privacy",
    "email",
    "electron"
  ],
  "author": "User",
  "license": "MIT",
  "build": {
    "appId": "com.identityscanner.app",
    "productName": "Identity Scanner",
    "mac": {
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "category": "Network"
    }
  }
}
